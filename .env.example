# Токен НОВОГО бота (создать у @BotFather) — он открывает Mini App и шлёт уведомления.
BOT_TOKEN=your_new_bot_token

# Токен kinopoisk.dev — выдаёт @kinopoiskdev_bot в Telegram (без email!).
# Несколько токенов через запятую — ротация в kinopoisk.py суммирует их лимиты.
KINOPOISK_TOKEN=your_kinopoisk_token

# Дневной бюджет внешних поисковых вызовов. Если не задан — auto-обчислюється:
# KP_DAILY_PER_TOKEN (за умовч. 180) × кількість токенів вище. 4 токени → 720/добу.
# Задай явно, якщо хочеш інший ліміт (напр. нижчий для free-тарифу).
# DAILY_SEARCH_BUDGET=
# KP_DAILY_PER_TOKEN=180

# OMDb — fallback-источник (ключ можно взять тот же, что в movie_bot).
OMDB_API_KEY=your_omdb_api_key

# PostgreSQL в production (Neon). Локально оставь пустым — будет SQLite.
DATABASE_URL=

# Встроенная админка подборок. Эти Telegram ID всегда имеют доступ к созданию
# и редактированию подборок; обычные пользователи видят их только для чтения.
ADMIN_USER_IDS=123456789,987654321

# Служебный токен для закрытых endpoint-ов обслуживания (не обязателен локально).
ADMIN_TOKEN=
