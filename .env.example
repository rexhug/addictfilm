# Токен НОВОГО бота (создать у @BotFather) — он открывает Mini App и шлёт уведомления.
BOT_TOKEN=your_new_bot_token

# Токен kinopoisk.dev — выдаёт @kinopoiskdev_bot в Telegram (без email!).
KINOPOISK_TOKEN=your_kinopoisk_token

# OMDb — fallback-источник (ключ можно взять тот же, что в movie_bot).
OMDB_API_KEY=your_omdb_api_key

# Username бота без @. Нужен для ссылки-приглашения партнёра.
# У бота должна быть настроена Main Mini App в @BotFather.
BOT_USERNAME=your_movie_bot

# PostgreSQL для постійного публічного запуску. Локально залиш порожнім —
# застосунок використає movies.db. Railway підставляє це значення зі свого
# сервісу PostgreSQL, секрет у Git не потрапляє.
DATABASE_URL=
